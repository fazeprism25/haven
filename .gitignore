__pycache__/
*.pyc
.venv/
.env
.aider*
haven_data/

# Windows/OneDrive local artifacts that have no business in the repo --
# /Downloads/ is the user's real OS Downloads folder (it ends up nested
# under this OneDrive path); desktop.ini is Explorer folder metadata and
# can appear in any directory, so it's left unanchored.
/Downloads/
desktop.ini

# Real local config (see config/*.env.example for the committed templates)
config/*.env

# The user's chosen Obsidian vault root (see POST /api/v1/vault) -- machine-
# specific, never something to commit.
config/vault_selection.json

# Memory Spaces registry (see obsidian/server/README.md) -- machine-specific,
# supersedes vault_selection.json above.
config/spaces.json

# Query Rewriting on/off toggle (see obsidian/server/main.py's
# _QUERY_REWRITING_CONFIG_PATH) -- machine-specific runtime state, same
# pattern as spaces.json above.
config/query_rewriting_setting.json

# Regeneratable output of benchmarks/analysis/classify_failure.py -- the
# authoritative benchmark report is benchmarks/results/final_report.md.
benchmarks/reports/

# Per-run benchmark logs -- regeneratable, and leak the local machine's
# absolute file paths via Python DeprecationWarning stack traces.
benchmarks/results/*_run_logs/

# In-progress checkpoint for a still-running run_benchmarks.py invocation
# (see run_benchmarks._checkpoint_path) -- deleted automatically once that
# adapter's run finishes; never a finished, canonical artifact.
benchmarks/results/.checkpoint_*.json
